# `pnpm test` = offline. `pnpm test:live` = real SMTP when this file is set.
MAIL_FROM=you@yourdomain.com
MAIL_TO=you@yourdomain.com
MAIL_HOST=smtp.yourdomain.com
# Optional: external inbox for the direct-MX test (Proton, Gmail, etc.; MX resolved from domain).
# MAIL_TO_MX=you@example.com
# Optional: extra PEM for self-signed relay — merged with Node default roots (does not replace them).
# SMTP_TLS_CA=/path/to/ca.pem
