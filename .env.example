# Copy to .env in this package root.
# Default `pnpm test` = unit tests. Remote check: `pnpm test:live`.
#
# --- TLS verification ---
# See @trasherdk/smtp-channel .env.example: full chain on server, SMTP_TLS_CA (or SMTP_TLS_CERT) / NODE_EXTRA_CA_CERTS,
# MAIL_TLS_SERVERNAME when the cert name does not match MAIL_HOST. MAIL_TLS_INSECURE=1 disables verify (debug only).

# MAIL_HOST = server you connect to. EHLO defaults to MAIL_FROM’s domain unless MAIL_EHLO_HOST is set.
MAIL_HOST=smtp.example.com
MAIL_FROM=you@example.com
MAIL_TO=recipient@example.com
# MAIL_PORT=587
# MAIL_STARTTLS=1
# MAIL_SECURE=1
# MAIL_TLS_SERVERNAME=mail.example.com
# SMTP_TLS_CA=/etc/ssl/certs/trader-internet-ca.pem
# SMTP_TLS_CERT=/path/to/ca-chain-or-intermediate.pem
